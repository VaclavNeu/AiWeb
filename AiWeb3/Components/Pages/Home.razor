@page "/home"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using AiWeb3.Data
@rendermode InteractiveServer
@inject IStringLocalizer<AiWeb3.Components.Pages.HomeText> _localizer

<PageTitle>WebGenerace</PageTitle>



    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" /> 
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" /> 
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> 
    <link rel="stylesheet" href="/theme.css" /> 
    <script src="/js/interop.js"></script> 
    <script src="/js/theme.js"></script> 
    <script>window.theme && window.theme.init();</script>



<section class="py-5 position-relative hero-wrap">
    <div class="container position-relative">
        <div class="hero-panel rounded-4 p-4 p-lg-5 shadow-lg mx-auto text-center">
            <h1 class="display-5 fw-bold mb-3">Vytvoř web z popisu</h1>
            <p class="lead mb-4 text-opacity-75">
                Napiš, co má web obsahovat, a AiWeb z textu vygeneruje hotovou stránku.
            </p>
        </div>
    </div>
</section>


<section id="generator" class="py-4">
    <div class="container">
        <div class="row g-4 align-items-start">
            <!-- LEVÁ 1/2:  -->
            <div class="col-12 col-lg-6">
                <div class="card card-hero shadow-sm">
                    <div class="card-body">
                        <h2 class="h4 mb-3"><i class="bi bi-pencil-square me-2"></i>Popiš svůj web</h2>

                        <label for="prompt" class="form-label small text-muted">Zadej popis webu (pokus se o co nejpřesnější popis prvků)</label>
                        <textarea id="prompt"
                                  @bind="message"
                                  class="form-control prompt-box mb-3"
                                  placeholder="Např. landing page pro kavárnu s galerií a kontaktním formulářem"></textarea>
                      
                                <div class="d-flex gap-2">
                                    <button class="btn btn-primary" @onclick="SendAsync">
                                        <i class="bi bi-lightning-charge me-1"></i> Generovat
                                    </button>
                                    <button class="btn btn-outline-secondary" type="button" data-bs-toggle="modal" data-bs-target="#previewModal">
                                        <i class="bi bi-eye me-1"></i> Otevřít náhled
                                    </button>
                                </div>
                                <AuthorizeView>
                                    <NotAuthorized>
                                    <div class="alert alert-info" style="margin-top: 10px">
                            Pro práci s uloženými weby se prosím
                                    <a href="/Identity/Account/Login?returnUrl=@Uri.EscapeDataString(GetLocalReturnUrl())">přihlas</a>.
                                     </div>
                            </NotAuthorized>
                        </AuthorizeView>
                        @if (isGenerating)
                        {
                            <div class="progress mt-3">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     role="progressbar"
                                     style=@($"width:{generationProgress}%")
                                     aria-valuenow="@generationProgress" aria-valuemin="0" aria-valuemax="100">
                                    @generationProgress%
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(_lastSavedUrl))
                        {
                            <div class="alert alert-success mt-3 mb-0">
                                Uloženo @_SiteName<span>:</span>
                                <a href="@_lastSavedUrl" target="_blank" rel="noopener noreferrer">otevřít</a>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- PRAVÁ 1/2: -->
            <div class="col-12 col-lg-6">
                <AuthorizeView>
                    <Authorized>
                        <div class="card card-hero shadow-sm position-sticky" style="top:1rem;">
                            <div class="card-body">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <h2 class="h5 m-0"><i class="bi bi-folder2-open me-2"></i>Moje uložené stránky</h2>
                                    <button class="btn btn-sm btn-outline-danger ms-auto" @onclick="ToggleDeleteMode">
                                        <i class="bi bi-trash3 me-1"></i> Režim odstranění
                                    </button>
                                </div>

                                @if (_loadingSites)
                                {
                                    <div class="d-flex align-items-center gap-2 text-muted">
                                        <div class="spinner-border spinner-border-sm" role="status"><span class="visually-hidden">Načítám…</span></div>
                                        <span>Načítám uložené stránky…</span>
                                    </div>
                                }
                                else
                                {
                                    @if (_mySites?.Any() == true)
                                    {
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var s in _mySites)
                                            {
                                                var url = s.Assets.FirstOrDefault(a => a.Kind == "html")?.Path ?? "#";
                                                <a class="btn btn-outline-secondary" href="@url" target="_blank" rel="noopener">
                                                    <i class="bi bi-filetype-html me-1"></i>@s.Title
                                                </a>
                                            }
                                        </div>
                                    }
                                    else if (!_deleteMode)
                                    {
                                        <div class="text-muted">Zatím nic uloženého.</div>
                                    }
                                }

                                @if (_deleteMode)
                                {
                                    <hr class="my-3" />
                                    @if (_mySites?.Any() == true)
                                    {
                                        <div class="d-flex flex-wrap gap-2 align-items-center">
                                            <select class="form-select w-auto" @bind="_siteToDeleteId" aria-label="Vyber stránku ke smazání">
                                                @foreach (var s in _mySites)
                                                {
                                                    <option value="@s.Id">@s.Title</option>
                                                }
                                            </select>
                                            <button class="btn btn-danger" @onclick="DeleteSelectedSiteAsync">
                                                <i class="bi bi-trash3 me-1"></i> Smazat
                                            </button>
                                            @if (!string.IsNullOrEmpty(_deleteError))
                                            {
                                                <div class="text-danger ms-2">@_deleteError</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted">Nemáš nic uloženého.</div>
                                    }
                                }
                            </div>
                        </div>
                    </Authorized>

                    
                </AuthorizeView>
            </div>
            
        </div>
    </div>  
</section>


<div class="modal fade" id="previewModal" tabindex="-1" aria-labelledby="previewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content card-surface">
            <div class="modal-header">
                <h5 class="modal-title" id="previewModalLabel"><i class="bi bi-eye me-2"></i>Náhled stránky</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
            <div class="modal-body">
                <iframe srcdoc="@selectedResponse" width="1080" height="600" style="border:none;"></iframe>
            </div>
            <div class="modal-footer">
                <button class="btn btn-primary" @onclick="SaveHtmlAsync" data-bs-dismiss="modal">
                    <i class="bi bi-save2 me-1"></i> Uložit do DB
                </button>
            </div>
        </div>
    </div>
</div>

