@page
@model ResendEmailConfirmationModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AiWeb3.Components.Pages.HomeText> _localizer
@{
    ViewData["Title"] = "Resend email confirmation";
}
<section class="hero-wrap py-5 min-vh-75 d-flex align-items-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6 col-xl-5">
            <div class="hero-panel rounded-4 py-4 p-lg-5 shadow-lg">
    
                 <!-- <h1 class="text-center">@_localizer["ResEmailVerif"]</h1> -->
                 <h1 class="text-center">@_localizer["EnterEmail"]</h1>
                 <p class="text-center">Do několika minut ti na něj přijde potvrzení</p>
                 <hr />
                 <div class="row justify-content-center">
                     <div class="">
                         <form method="post" class="vstack gap-1">
                             <div asp-validation-summary="All" class="text-danger" role="alert"></div>
                             <div class="form-floating mb-3">
                                 <input asp-for="Input.Email" class="form-control" aria-required="true" placeholder="name@example.com" />
                                 <label asp-for="Input.Email" class="form-label"></label>
                                 <span asp-validation-for="Input.Email" class="text-danger"></span>
                             </div>
                             <button type="submit" class="w-100 btn btn-lg btn-primary">Resend</button>
                         </form>
                     </div>
                 </div>
            </div>
            </div>
        </div>
    </div>
</section>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"
        integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous"></script>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
